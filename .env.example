# ==============================================
# Cyber Pulse 配置文件模板
# ==============================================
#
# 注意: 此文件为模板，实际配置由部署脚本自动生成
#
# 首次部署时，请运行:
#   ./scripts/cyber-pulse.sh deploy
#
# 脚本将自动生成安全密码并创建 .env 文件
#
# 如需手动配置，请复制此文件为 .env 并填写值:
#   cp .env.example .env
# ==============================================

# 数据库配置
POSTGRES_USER=cyberpulse
POSTGRES_PASSWORD=<自动生成或手动设置>
POSTGRES_DB=cyberpulse

# 数据库连接 URL（Docker 内部使用）
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://cyberpulse:PASSWORD@postgres:5432/cyberpulse

# Redis 配置
REDIS_URL=redis://redis:6379/0

# Dramatiq 消息队列
DRAMATIQ_BROKER_URL=redis://redis:6379/1

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# JWT 安全配置
# SECRET_KEY 应为 64 字符的随机字符串
SECRET_KEY=<自动生成或手动设置>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/cyber_pulse.log

# 环境
ENVIRONMENT=production

# ==============================================
# 以下为可选配置
# ==============================================

# 外部服务 API Keys (可选)
# YOUTUBE_API_KEY=your-youtube-api-key